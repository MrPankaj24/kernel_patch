# Mountify Support
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

#Ubuntu Chroot
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

#Run x86_x64 Natively
CONFIG_BINFMT_MISC=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_ELF=y

#SysVIPC
CONFIG_SYSVIPC=y
CONFIG_SYSCTL=y
CONFIG_SYSVIPC_SYSCTL=y
CONFIG_PROC_SYSCTL=y
CONFIG_POSIX_MQUEUE=y

#Container Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y

#Threading
#CONFIG_FUTEX=y

# File operations
#CONFIG_FILE_LOCKING=y

# Device management
CONFIG_DEVTMPFS_MOUNT=y

# Extended filesystem features
#CONFIG_TMPFS_POSIX_ACL=y
#CONFIG_TMPFS_XATTR=y
#CONFIG_EXT4_FS_POSIX_ACL=y
#CONFIG_EXT4_FS_SECURITY=y

#Event handling
#CONFIG_EPOLL=y
#CONFIG_EVENTFD=y
#CONFIG_SIGNALFD=y
#CONFIG_TIMERFD=y

# File monitoring
#CONFIG_INOTIFY_USER=y

# Security
#CONFIG_SECCOMP=y
#CONFIG_SECCOMP_FILTER=y

# Networking features
CONFIG_IPV6=y
CONFIG_PACKET=y

# Legacy PTY (for compatibility)
CONFIG_LEGACY_PTYS=y
CONFIG_LEGACY_PTY_COUNT=256

#Advanced cgroup controllers
#CONFIG_CGROUP_CPUACCT=y
#CONFIG_CGROUP_SCHED=y
#CONFIG_CGROUP_FREEZER=y
#CONFIG_CGROUP_PIDS=y
#CONFIG_MEMCG_SWAP=y

# Overlay filesystem (for Docker-like functionality)
CONFIG_OVERLAY_FS=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_EXT4_FS_POSIX_ACL=y

# FUSE (for userspace filesystems like sshfs, AppImage)
CONFIG_FUSE_FS=y

# Loop devices (for mounting disk images)
CONFIG_BLK_DEV_LOOP=y

# Async I/O (for database servers and high-performance apps)
CONFIG_AIO=y

#Lxc Support
#CONFIG_EXPERT=y
CONFIG_BT_HCIVHCI=y
CONFIG_NULL_TTY=y
CONFIG_FHANDLE=y
CONFIG_UNIX_DIAG=y
CONFIG_PACKET_DIAG=y
#CONFIG_NETLINK_DIAG=m
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
ONFIG_IP6_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y
CONFIG_MACVLAN=y
CONFIG_PROC_CHILDREN=y
CONFIG_CHECKPOINT_RESTORE=y
#CONFIG_BPF_SYSCALL=y
#CONFIG_CGROUP_BPF=y
CONFIG_VETH=y
CONFIG_BRIDGE=y

#Docker
CONFIG_NF_NAT=y
CONFIG_IP_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_IP_VS=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_VXLAN=m
CONFIG_BRIDGE_VLAN_FILTERING=y

#Docker Optional
#CONFIG_BLK_DEV_THROTTLING=y
#CONFIG_CGROUP_PERF=y
#CONFIG_CGROUP_HUGETLB=y
#CONFIG_NET_CLS_CGROUP=y
#CONFIG_CFS_BANDWIDTH=y
#CONFIG_IPVLAN=y
#CONFIG_SECURITY_APPARMOR=y
#CONFIG_IP_SCTP=y

#Docker Remaining
#CONFIG_NFT_FIB=y
#CONFIG_NFT_FIB_IPV4=y
#CONFIG_NFT_FIB_IPV6=y
#CONFIG_NFT_NAT=y
#CONFIG_NETFILTER=y
#CONFIG_NETFILTER_ADVANCED=y
#CONFIG_NF_NAT_IPV4=y
#CONFIG_NF_NAT_IPV6=y

#More Connections
#CONFIG_NFT_CT=y
#CONFIG_NFT_MASQ=y
#CONFIG_NFT_FIB=y
#CONFIG_NFT_FIB_IPV6=y
#CONFIG_NFT_FIB_IPV4=y

#Btrfs
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y

#Maintener
CONFIG_LOCALVERSION_AUTO=n
CONFIG_LOCALVERSION="@MrPankaj24,@prisma"
#CONFIG_DEFAULT_HOSTNAME="MrPankaj24"

# Core namespace support (essential for isolation and running init systems)
CONFIG_NAMESPACES=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_MNT_NS=y
CONFIG_CGROUP_NS=y  # Required for Cgroup isolation (v4.1.0+)

# Seccomp support (enables syscall filtering and security hardening)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Control groups support (required for systemd and resource accounting)
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y

# Device filesystem support (enables hardware access when --hw-access is enabled)
CONFIG_DEVTMPFS=y

# Firmware loading support (optional, used when --hw-access is enabled)
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_FW_LOADER_COMPRESS=y

# MSS clamping
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y

#NTSYCE
CONFIG_NTSYNC=y

#BBRv3 Test
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
# BBRv3 REQUIRES Fair Queuing (FQ) to function correctly
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y

# WIREGUARD
CONFIG_NET_UDP_TUNNEL=y
CONFIG_WIREGUARD=y
CONFIG_WIREGUARD_DEBUG=n
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_POLY1305=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_BLAKE2S=y
